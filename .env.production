# Flask基础配置
FLASK_APP=run.py
FLASK_CONFIG=production
SECRET_KEY=请修改为随机生成的密钥
JWT_SECRET_KEY=请修改为随机生成的JWT密钥

# 数据库配置
DATABASE_URL=sqlite:///instance/app.db

# 智谱AI配置（必填）
# 获取地址: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=

# 服务器配置
FLASK_ENV=production
FLASK_DEBUG=False

